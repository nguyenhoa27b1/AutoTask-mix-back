# Email Configuration
# Set to 'true' to send real emails via Gmail, 'false' for mock mode (console log only)
USE_REAL_EMAIL=false

# Gmail SMTP Settings (required only if USE_REAL_EMAIL=true)
# Get App Password from: https://myaccount.google.com/apppasswords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password-here

# Example:
# USE_REAL_EMAIL=true
# GMAIL_USER=taskflow.app@gmail.com
# GMAIL_APP_PASSWORD=abcd efgh ijkl mnop
